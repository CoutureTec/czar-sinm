# Copie este arquivo para .env e preencha com suas credenciais:
#   cp .env.example .env

# Ambiente: hml | prd | <customizado>
SINM_AMBIENTE=hml

# Para ambientes customizados (SINM_AMBIENTE diferente de hml/prd),
# as três variáveis abaixo tornam-se obrigatórias:
#
# URL base da API ZarcNM (sem barra final)
# SINM_BACKEND_URL=https://endereco-do-zarcnm
#
# URL base do Keycloak incluindo o segmento /realms (sem barra final)
# SINM_KEYCLOAK=https://endereco-do-keycloak/realms
#
# Nome do realm no Keycloak
# SINM_KEYCLOAK_REALM=nome-do-realm

# Credenciais do usuário
SINM_USERNAME=seu.usuario@embrapa.br
SINM_PASSWORD=sua_senha

# Credenciais do client Keycloak (fornecidas pela equipe SINM)
SINM_CLIENT_ID=seu-client-id (nome do client)
SINM_CLIENT_SECRET=seu-client-secret (chave criptografada do client)

# Tipo de autenticação OAuth2 (opcional; padrão: client_credentials)
# Use 'password' (ROPC) para que o usuário humano seja o autenticado na API.
SINM_GRANT_TYPE=password
