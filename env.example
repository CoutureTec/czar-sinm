# Copie este arquivo para .env e preencha com suas credenciais:
#   cp .env.example .env

# Ambiente: hml | prd
ZARCNM_AMBIENTE=hml

# Credenciais do usuário
ZARCNM_USERNAME=seu.usuario@embrapa.br
ZARCNM_PASSWORD=sua_senha

# Credenciais do client Keycloak (fornecidas pela equipe ZARC-NM)
ZARCNM_CLIENT_ID=seu-client-id (nome do client)
ZARCNM_CLIENT_SECRET=seu-client-secret (chave criptografada do client)
